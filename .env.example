# Copy this file to `.env` and fill in real values.
# `.env` is gitignored — never commit secrets.

# --- Odds / market data providers (placeholders for the betting extension) ---
ODDS_API_KEY=
PINNACLE_USERNAME=
PINNACLE_PASSWORD=
BETFAIR_APP_KEY=
BETFAIR_SESSION_TOKEN=
# Or, instead of a session token, credentials for interactive login:
BETFAIR_USERNAME=
BETFAIR_PASSWORD=

# --- Optional data scraping config ---
USER_AGENT=worldCup2026-research/0.1

# --- Runtime config ---
LOG_LEVEL=INFO
MONTE_CARLO_RUNS=20000
RANDOM_SEED=42
